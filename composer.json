{
    "name": "chat/app",
    "description": "Production-ready web chat application",
    "type": "project",
    "require": {
        "php": "^8.4",
        "cboden/ratchet": "^0.4",
        "phpmailer/phpmailer": "^7.0",
        "react/event-loop": "^1.5",
        "react/http": "^1.10",
        "react/socket": "^1.16"
    },
    "autoload": {
        "psr-4": {
            "Chat\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
